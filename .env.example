TIKTOK_CLIENT_KEY=your_client_key
TIKTOK_CLIENT_SECRET=your_client_secret

# OAuth auth script settings
TIKTOK_REDIRECT_URI=http://localhost:8080/callback
TIKTOK_SCOPES=user.info.basic,video.list
TIKTOK_DISABLE_AUTO_AUTH=0
TIKTOK_OPEN_BROWSER=true
TIKTOK_CALLBACK_TIMEOUT_SECONDS=180
TIKTOK_TOKEN_PATH=tiktok_tokens.json

# Pipeline settings
TIKTOK_DB_PATH=data/tiktok_analytics.db
TIKTOK_VIDEO_PAGE_LIMIT=5
TIKTOK_VIDEO_PAGE_SIZE=20
TIKTOK_REFRESH_BUFFER_SECONDS=300

# Scheduler and dashboard
TIKTOK_SCHEDULE_TIME=03:30
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8050

# Alerts
ALERT_MIN_TOTAL_VIEWS=100
ALERT_GROWTH_DROP_PERCENT=30
